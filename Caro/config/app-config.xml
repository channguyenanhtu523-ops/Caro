<appConfig>
  <server>
    <host>127.0.0.1</host>
    <port>5050</port>
    <heartbeatSeconds>4</heartbeatSeconds>
    <readTimeoutMillis>16000</readTimeoutMillis>
    <connectTimeoutMillis>5000</connectTimeoutMillis>
